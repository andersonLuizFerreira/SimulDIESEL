# Normalize line endings in repo
* text=auto

# ===== C# / Visual Studio =====
*.cs text eol=crlf
*.Designer.cs text eol=crlf
*.sln text eol=crlf
*.csproj text eol=crlf
*.resx text eol=crlf

# ===== Firmware / C / C++ / Arduino =====
*.h   text eol=lf
*.hpp text eol=lf
*.c   text eol=lf
*.cpp text eol=lf
*.ino text eol=lf

# ===== Docs / Config / Infra =====
*.md text eol=lf
*.txt text eol=lf
*.ini text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.xml text eol=lf

# Binary
*.png binary
*.jpg binary
*.pdf binary
*.zip binary